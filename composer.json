{
    "name": "olegantoniuk/aoe2-companion-web",
    "description": "AoE2 Companion - unit and civilization browser",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "yiisoft/yii2": "~2.0.52",
        "yiisoft/yii2-bootstrap5": "~2.0"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "config": {
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
